<header role="banner">
  <br-container>
      <a href="/" id="logo">
        <%= site.metadata.title %>
      </a>

      <nav id="mainnav" class="main-nav" aria-label="Main">
          <ul role="list" id="main-nav-ul">
              <% site.data.nav.each do |item| %>
                <% if item.button %>
                  <li>
                    <button class="expand-button" aria-expanded="true" aria-controls="products-level-2">
                      <%= item.title %>
                    </button>
                    <ul id="products-level-2" class="">
                      <% item.links do |item| %>
                        <li><%= link_to item.title, item.url %></li>
                      <% end %>
                    </ul>
                  </li>
                <% else %>
                  <li><%= link_to item.title, item.url %></li>
                <% end %>
              <% end %>
          </ul>
      </nav>

  </br-container>
</header>


<template id="burger-template">
  <button type="button" aria-expanded="false" aria-label="Menu" aria-controls="mainnav">
    <svg width="24" height="24" aria-hidden="true">
      <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z">
    </svg>
  </button>
</template>
